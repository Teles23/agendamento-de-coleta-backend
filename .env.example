# ============================================================
# ENVIRONMENT VARIABLES - Copy this file to .env and fill in
# cp .env.example .env
# ============================================================

# --- Application ---
PORT=3000
NODE_ENV=development

# --- Database ---
# Neon pooled connection string used by the running API.
# Copy the "pooled" URL from Neon. The host usually contains "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@EP-HOST-POOLER.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Neon direct connection string used by Prisma for migrations.
# Copy the "direct" URL from Neon.
DIRECT_URL="postgresql://USER:PASSWORD@EP-HOST.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# --- Authentication ---
# IMPORTANT: Change this to a strong, random secret in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET"
JWT_EXPIRES_IN="1d"

# --- AI (Google Gemini) ---
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# --- CORS ---
# URL of the frontend app (used to restrict CORS)
FRONTEND_URL="http://localhost:5173"
