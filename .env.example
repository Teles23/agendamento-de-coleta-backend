# ============================================================
# ENVIRONMENT VARIABLES - Copy this file to .env and fill in
# cp .env.example .env
# ============================================================

# --- Application ---
PORT=3000
NODE_ENV=development

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coleta_db"

# --- Authentication ---
# IMPORTANT: Change this to a strong, random secret in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET"
JWT_EXPIRES_IN="1d"

# --- AI (Google Gemini) ---
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# --- CORS ---
# URL of the frontend app (used to restrict CORS)
FRONTEND_URL="http://localhost:5173"
